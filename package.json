{
  "name": "macbook-overlay",
  "version": "0.1.0",
  "description": "A frosted always-on-top markdown overlay for macOS, invisible to screen sharing.",
  "main": "main.js",
  "author": "jogendra-india",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "electron": "^31.7.6",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.jogendra.macbookoverlay",
    "productName": "Markdown Overlay",
    "directories": { "buildResources": "build", "output": "dist" },
    "files": ["main.js", "preload.js", "renderer.html", "renderer.js", "package.json"],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "dir"],
      "icon": "build/icon.png",
      "identity": null
    }
  }
}
